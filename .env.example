APP_NAME="SIOPK Badung"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/siopk-badung/public

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=siopk_badung
DB_USERNAME=root
DB_PASSWORD=

FILESYSTEM_DISK=public
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
APP_LOCALE=id
APP_TIMEZONE=Asia/Makassar

# ─────────────────────────────────────────────
# AI PROVIDER — Multi-provider support
# ─────────────────────────────────────────────
# Provider yang didukung: claude, openai, deepseek, groq, custom
#   custom  → isi CUSTOM_AI_* variables + CUSTOM_AI_TYPE (openai/claude)
#   groq    → gratis, daftar di https://console.groq.com
#   deepseek → murah, daftar di https://platform.deepseek.com
# ─────────────────────────────────────────────
AI_PROVIDER=claude

# Claude (Anthropic)
CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Groq (gratis)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Custom (Ollama, LM Studio, OpenRouter, dll)
CUSTOM_AI_API_KEY=
CUSTOM_AI_API_URL=
CUSTOM_AI_MODEL=
# CUSTOM_AI_TYPE=openai    ← "openai" atau "claude"

# WhatsApp Notifikasi — Fase 7 (opsional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
